{
  "name": "bazi-agent-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx src/scripts/migrate.ts",
    "build:bazi-mcp": "npm --prefix ../bazi-mcp-dev run tsc"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "jose": "^6.2.2",
    "pg": "^8.13.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.11",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
